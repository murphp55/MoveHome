<?xml version="1.0"?>
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        id="a3421fee-e796-4a0c-b1d8-5ea5d1a40a3d"
        name="MoveHome"
        version="1.0.0"
        type="watchApp"
        minApiLevel="3.4.0">

        <iq:products>
            <iq:product id="fenix6"/>
            <iq:product id="fenix6s"/>
            <iq:product id="fenix6pro"/>
            <iq:product id="fenix7"/>
            <iq:product id="fenix7s"/>
            <iq:product id="vivoactive4"/>
            <iq:product id="venu2"/>
            <iq:product id="fr945"/>
            <iq:product id="fr255"/>
        </iq:products>

        <iq:permissions>
            <iq:uses-permission id="Sensor"/>
            <iq:uses-permission id="Communications"/>
        </iq:permissions>

        <iq:languages>
            <iq:language id="eng"/>
        </iq:languages>

        <!-- Glance: visible by swiping up from the watch face, one tap launches app -->
        <iq:glance name="MoveHomeGlance">
            <iq:dataField name="MoveHomeApp"/>
        </iq:glance>

        <!-- Background service: runs on a schedule when the app is closed -->
        <iq:background>
            <iq:schedule type="temporal"/>
        </iq:background>

    </iq:application>
</iq:manifest>
